{
  "name": "@inharness-ai/c4s-plugin-simple-database-tables",
  "version": "0.1.0",
  "description": "claude4spec plugin contributing the database-table entity (SQLite table database_table): columns, indexes, soft foreign keys; exposed over MCP, HTTP and React renderers.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./frontend": {
      "types": "./dist/frontend.d.ts",
      "import": "./dist/frontend.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "dev:link": "node scripts/link-into-host.mjs",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@c4s/plugin-runtime": "*",
    "@inharness-ai/agent-adapters": "^0.8.4",
    "@tanstack/react-query": "^5.0.0",
    "@tiptap/core": "^2.0.0",
    "better-sqlite3": "*",
    "express": "^4.22.2",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zod": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "@c4s/plugin-runtime": {
      "optional": true
    },
    "@inharness-ai/agent-adapters": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "@tiptap/core": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.9.0"
  }
}
